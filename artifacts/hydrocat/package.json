{
  "name": "@workspace/hydrocat",
  "version": "1.0.0",
  "description": "HydroCat — a pixel-art cat that lives in your macOS Dock and keeps you hydrated",
  "main": "main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac --dir",
    "pack": "electron-builder --mac --dir"
  },
  "dependencies": {
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.hydrocat.app",
    "productName": "HydroCat",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      "assets/**/*"
    ]
  }
}
