{
  "name": "@workspace/hydrocat",
  "version": "1.0.0",
  "description": "HydroCat — a pixel-art cat that lives in your macOS Dock and keeps you hydrated",
  "main": "main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac --dir",
    "pack": "electron-builder --mac --dir",
    "slice-sprites": "node scripts/slice-sprites.js"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "pngjs": "^7.0.0"
  },
  "build": {
    "appId": "com.hydrocat.app",
    "productName": "HydroCat",
    "asar": false,
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "dmg": {
      "title": "HydroCat",
      "icon": "assets/icon.png",
      "iconSize": 128,
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "afterSign": "scripts/notarize.js"
  }
}
